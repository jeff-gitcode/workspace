{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/llama-4-scout",
  "enabled_providers": ["litellm", "github-copilot"],
  "mcp": {
    "md2card": {
      "type": "local",
      "command": ["npx", "-y", "md2card-mcp-server@latest"],
      "enabled": true,
      "environment": {
        "MD2CARD_API_KEY": "{env:MD2CARD_API_KEY}"
      }
    }
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://litellm:4000/v1",
        "apiKey": "sk-litellm-demo"
      },
      "models": {
        "llama-4-scout": { "name": "Llama 4 Scout 17B (Groq - free, fast, requires API key)" },
        "llama-3.3-70b": { "name": "Llama 3.3 70B (Groq - free, requires API key, 12K TPM limit)" },
        "ollama/qwen2.5-coder:1.5b": { "name": "Qwen 2.5 Coder 1.5B (Ollama - local, no API key)" },
        "ollama/llama3.1:8b": { "name": "Llama 3.1 8B (Ollama - free, no API key)" },
        "gpt-4o": { "name": "GPT-4o (OpenAI)" },
        "gpt-4o-mini": { "name": "GPT-4o Mini (OpenAI)" },
        "claude-3-5-sonnet": { "name": "Claude 3.5 Sonnet (Anthropic)" },
        "claude-3-5-haiku": { "name": "Claude 3.5 Haiku (Anthropic)" },
        "gemini-2.0-flash": { "name": "Gemini 2.0 Flash (Google)" },
        "gemini-1.5-pro": { "name": "Gemini 1.5 Pro (Google)" },
        "mistral-large": { "name": "Mistral Large" },
        "command-r-plus": { "name": "Command R+ (Cohere)" },
        "llama-3.1-405b": { "name": "Llama 3.1 405B (Together AI)" },
        "sonar-pro": { "name": "Sonar Pro (Perplexity)" },
        "grok-2": { "name": "Grok 2 (xAI)" },
        "deepseek-chat": { "name": "DeepSeek Chat" }
      }
    }
  }
}
