# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Groq
GROQ_API_KEY=

# Together AI
TOGETHERAI_API_KEY=

# Perplexity
PERPLEXITYAI_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

