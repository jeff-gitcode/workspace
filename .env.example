# Copy this file to .env and fill in the keys for providers you want to use.
# LiteLLM will only activate models for keys that are set.
# The file must exist (even if empty) for Docker Compose to start.

# -----------------------------------------------------------------------
# DEFAULT: Groq (FREE, fast - https://console.groq.com, no credit card)
# OpenCode uses llama-4-scout via Groq by default when this key is set.
# -----------------------------------------------------------------------
GROQ_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Cohere
COHERE_API_KEY=

# Together AI
TOGETHERAI_API_KEY=

# Perplexity
PERPLEXITYAI_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=

# MD2Card (optional - for converting markdown to knowledge cards)
# Get your API key from https://md2card.cn/zh/login
MD2CARD_API_KEY=
