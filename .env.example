# Copy this file to .env and fill in the keys for providers you have.
# LiteLLM will only activate models for keys that are set.

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=
