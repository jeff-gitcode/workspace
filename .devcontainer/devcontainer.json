{
  "name": "litellm-demo",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "npm install -g opencode-ai",
  "postAttachCommand": "opencode",
  "remoteUser": "node",
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "sst-dev.opencode"
      ]
    }
  }
}
